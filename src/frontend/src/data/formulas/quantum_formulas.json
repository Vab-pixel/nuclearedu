{
  "formulas": [
    {
      "id": "schrodinger-td",
      "latex": "i\\hbar \\frac{\\partial}{\\partial t} \\Psi(\\mathbf{r}, t) = \\hat{H} \\Psi(\\mathbf{r}, t)",
      "description": "Time-dependent Schrödinger equation describing the evolution of a quantum state over time.",
      "variables": [
        { "symbol": "i", "meaning": "Imaginary unit" },
        {
          "symbol": "\\hbar",
          "meaning": "Reduced Planck constant (1.054571817 × 10⁻³⁴ J·s)"
        },
        { "symbol": "\\Psi", "meaning": "Wave function" },
        { "symbol": "\\hat{H}", "meaning": "Hamiltonian operator" }
      ],
      "category": "quantum-mechanics"
    },
    {
      "id": "schrodinger-ti",
      "latex": "\\hat{H} \\psi(\\mathbf{r}) = E \\psi(\\mathbf{r})",
