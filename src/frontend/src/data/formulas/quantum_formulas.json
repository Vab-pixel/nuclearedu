      "variables": [
        { "symbol": "\\hat{H}", "meaning": "Hamiltonian operator" },
        { "symbol": "\\psi", "meaning": "Spatial wave function" },
        { "symbol": "E", "meaning": "Energy eigenvalue" }
      ],
      "category": "quantum-mechanics"
    },
    {
