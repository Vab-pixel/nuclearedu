{
  "formulas": [
    {
      "id": "rydberg-general",
      "latex": "\\frac{1}{\\lambda} = R_H \\left( \\frac{1}{n_1^2} - \\frac{1}{n_2^2} \\right)",
      "description": "General Rydberg formula for hydrogen spectral lines.",
      "variables": [
        {
          "symbol": "R_H",
          "meaning": "Rydberg constant (1.0973731568160 × 10⁷ m⁻¹)"
        },
        { "symbol": "n_1", "meaning": "Lower principal quantum number" },
        {
          "symbol": "n_2",
          "meaning": "Upper principal quantum number (n₂ > n₁)"
        }
      ],
      "category": "spectral-series"
    },
    {
      "id": "lyman-series",
      "latex": "\\frac{1}{\\lambda} = R_H \\left( 1 - \\frac{1}{n^2} \\right), \\quad n = 2, 3, 4, \\dots",
      "description": "Lyman series: transitions to n=1 (ultraviolet).",
      "variables": [{ "symbol": "n", "meaning": "Upper level (≥ 2)" }],
      "category": "spectral-series"
    },
    {
      "id": "balmer-series",
      "latex": "\\frac{1}{\\lambda} = R_H \\left( \\frac{1}{4} - \\frac{1}{n^2} \\right), \\quad n = 3, 4, 5, \\dots",
      "description": "Balmer series: transitions to n=2 (visible light).",
      "variables": [{ "symbol": "n", "meaning": "Upper level (≥ 3)" }],
      "category": "spectral-series"
    },
    {
      "id": "balmer-formula",
      "latex": "\\lambda = 364.5 \\frac{n^2}{n^2 - 4} \\text{ nm}, \\quad n = 3, 4, 5, \\dots",
      "description": "Balmer's original empirical formula for visible hydrogen lines.",
      "variables": [],
      "category": "spectral-series"
    },
    {
      "id": "paschen-series",
      "latex": "\\frac{1}{\\lambda} = R_H \\left( \\frac{1}{9} - \\frac{1}{n^2} \\right), \\quad n = 4, 5, 6, \\dots",
      "description": "Paschen series: transitions to n=3 (infrared).",
      "variables": [{ "symbol": "n", "meaning": "Upper level (≥ 4)" }],
      "category": "spectral-series"
    },
    {
      "id": "brackett-series",
      "latex": "\\frac{1}{\\lambda} = R_H \\left( \\frac{1}{16} - \\frac{1}{n^2} \\right), \\quad n = 5, 6, 7, \\dots",
      "description": "Brackett series: transitions to n=4 (infrared).",
      "variables": [{ "symbol": "n", "meaning": "Upper level (≥ 5)" }],
      "category": "spectral-series"
    },
    {
      "id": "pfund-series",
      "latex": "\\frac{1}{\\lambda} = R_H \\left( \\frac{1}{25} - \\frac{1}{n^2} \\right), \\quad n = 6, 7, 8, \\dots",
      "description": "Pfund series: transitions to n=5 (infrared).",
      "variables": [{ "symbol": "n", "meaning": "Upper level (≥ 6)" }],
      "category": "spectral-series"
    },
    {
      "id": "humphreys-series",
      "latex": "\\frac{1}{\\lambda} = R_H \\left( \\frac{1}{36} - \\frac{1}{n^2} \\right), \\quad n = 7, 8, 9, \\dots",
      "description": "Humphreys series: transitions to n=6 (far infrared).",
      "variables": [{ "symbol": "n", "meaning": "Upper level (≥ 7)" }],
      "category": "spectral-series"
    },
    {
      "id": "photon-energy",
      "latex": "E = hf = \\frac{hc}{\\lambda}",
      "description": "Photon energy related to frequency and wavelength.",
      "variables": [
        {
          "symbol": "h",
          "meaning": "Planck constant (6.62607015 × 10⁻³⁴ J·s)"
        },
        { "symbol": "c", "meaning": "Speed of light (2.99792458 × 10⁸ m/s)" },
        { "symbol": "f", "meaning": "Frequency" }
      ],
      "category": "spectral-series"
    },
    {
      "id": "energy-transition",
      "latex": "\\Delta E = E_{n_2} - E_{n_1} = 13.6 \\left( \\frac{1}{n_1^2} - \\frac{1}{n_2^2} \\right) \\text{ eV}",
      "description": "Energy difference between two hydrogen levels.",
      "variables": [],
      "category": "spectral-series"
    },
    {
      "id": "rydberg-constant",
      "latex": "R_H = 1.0973731568160 \\times 10^7 \\text{ m}^{-1}",
      "description": "Rydberg constant for hydrogen.",
      "variables": [],
      "category": "constants"
    }
  ]
}
